<!-- PANEL 1: STATUS CHARTS -->
<div id="panel-status" class="panel active">
  <div class="two-col">
    <div class="card">
      <div class="sec-title">Configuration status — breakdown</div>
      <div class="chart-wrap" style="height:220px"><canvas id="cDonut"></canvas></div>
      <div class="legend" id="donutLeg"></div>
    </div>
    <div class="card">
      <div class="sec-title">Completed vs other — by specialist</div>
      <div class="chart-wrap" style="height:220px"><canvas id="cStacked"></canvas></div>
      <div class="legend" id="stackedLeg"></div>
    </div>
  </div>
