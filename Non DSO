  </div>
  <div class="card">
    <div class="sec-title">Tasks per specialist — total</div>
    <div class="chart-wrap" style="height:180px"><canvas id="cSpecBar"></canvas></div>
  </div>
</div>

<!-- PANEL 2: FILTERABLE LIST -->
<div id="panel-list" class="panel">
  <div class="card">
    <div class="filter-row">
      <select id="fSpec" onchange="renderTbl()"><option value="">All Specialists</option></select>
      <select id="fStatus" onchange="renderTbl()">
        <option value="">All Statuses</option>
        <option>Completed</option><option>On Hold</option><option>Not taken</option>
      </select>
      <input id="fSearch" placeholder="Search client or location…" oninput="renderTbl()" style="min-width:180px">
    </div>
    <div class="tbl-wrap">
      <table>
        <thead><tr>
          <th style="width:30px">#</th>
          <th style="width:120px">Specialist</th>
          <th style="width:160px">Client</th>
          <th style="width:130px">Location</th>
          <th style="width:95px">Config Status</th>
          <th style="width:90px">Start Date</th>
          <th style="width:95px">Completion Date</th>
          <th style="width:80px">Time Taken</th>
        </tr></thead>
        <tbody id="tblBody"></tbody>
      </table>
    </div>
    <div class="pag">
      <button class="pgb" id="pgPrev" onclick="chPage(-1)">← Prev</button>
      <span id="pgInfo"></span>
      <button class="pgb" id="pgNext" onclick="chPage(1)">Next →</button>
      <span id="pgCount" style="margin-left:auto"></span>
    </div>
  </div>
</div>

<!-- PANEL 3: AVG TIME -->
<div id="panel-avg" class="panel">
  <div class="two-col">
    <div class="card">
