// Avg table
const at=document.getElementById('avgTbl');
SCLIST.forEach(s=>{
  const st=specStats[s];
  if(!st||st.count===0){
    at.innerHTML+=`<tr><td><span class="dot" style="background:${SC[s]}"></span>${s}</td><td>${st?st.all:0}</td><td colspan="5" style="color:var(--color-text-secondary)">No timeline data</td></tr>`;
    return;
  }
  const avg=(st.total/st.count).toFixed(1);
  const mn=Math.min(...st.days), mx=Math.max(...st.days);
  const compRate=Math.round(rows.filter(r=>r.s===s&&r.st==='Completed').length/st.all*100);
  const mxColor=mx>=10?'#A32D2D':mx>=5?'#BA7517':'#3B6D11';
  at.innerHTML+=`<tr>
    <td><span class="dot" style="background:${SC[s]}"></span>${s}</td>
    <td>${st.all}</td>
    <td style="font-weight:500">${avg}d</td>
    <td>${st.total}d</td>
    <td style="color:#3B6D11">${mn}d</td>
    <td style="color:${mxColor}">${mx}d</td>
    <td><span class="badge b-comp">${compRate}%</span></td>
  </tr>`;
});

// ── FILTERABLE TABLE ──
let page=0; const PER=15; let filtered=[];
function renderTbl(){
  const sp=document.getElementById('fSpec').value;
  const st=document.getElementById('fStatus').value;
  const q=document.getElementById('fSearch').value.toLowerCase();
  filtered=rows.filter(r=>{
    if(sp&&r.s!==sp) return false;
    if(st&&r.st!==st) return false;
    if(q&&!(r.cl.toLowerCase().includes(q)||r.lo.toLowerCase().includes(q))) return false;
    return true;
  });
  page=0; renderPage();
}
function renderPage(){
  const start=page*PER, slice=filtered.slice(start,start+PER);
  const tb=document.getElementById('tblBody');
  tb.innerHTML='';
  slice.forEach((r,i)=>{
    const bc=r.st==='Completed'?'b-comp':r.st==='On Hold'?'b-hold':'b-not';
    const dc=SC[r.s]||'transparent';
    let daysTxt='—', daysColor='var(--color-text-secondary)';
    if(r.days!==null&&r.days!==undefined){
      daysTxt=r.days+'d';
      daysColor=r.days>=10?'#A32D2D':r.days>=5?'#BA7517':'#3B6D11';
    }
    tb.innerHTML+=`<tr>
      <td style="color:var(--color-text-secondary)">${start+i+1}</td>
      <td><span class="dot" style="background:${dc}"></span>${r.s||'—'}</td>
      <td title="${r.cl}">${r.cl}</td>
      <td title="${r.lo}">${r.lo}</td>
      <td><span class="badge ${bc}">${r.st}</span></td>
      <td>${r.sd}</td>
      <td>${r.cd}</td>
      <td style="font-weight:500;color:${daysColor}">${daysTxt}</td>
    </tr>`;
  });
  document.getElementById('pgInfo').textContent=`Page ${page+1} of ${Math.max(1,Math.ceil(filtered.length/PER))}`;
  document.getElementById('pgCount').textContent=`${filtered.length} records`;
  document.getElementById('pgPrev').disabled=page===0;
  document.getElementById('pgNext').disabled=(page+1)*PER>=filtered.length;
}
function chPage(d){page+=d;renderPage();}

function showPanel(name,el){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('panel-'+name).classList.add('active');
}

renderTbl();
